# =============================================================================
# NAZARETH — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it's already in .gitignore.
# =============================================================================

# ─── BACKEND (Golang) ────────────────────────────────────────────────────────

# Server
PORT=8080

# Database
DATABASE_PATH=./data/nazareth.db

# JWT secret for user sessions (generate: openssl rand -hex 32)
JWT_SECRET=

# ─── Strava ───────────────────────────────────────────────────────────────────
# Step 1: Go to https://www.strava.com/settings/api
# Step 2: Create an app (see STRAVA_APP_SETUP below)
# Step 3: Copy Client ID and Client Secret here

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match "Authorization Callback Domain" in your Strava app settings
# For local dev: http://localhost:8080/auth/strava/callback
STRAVA_REDIRECT_URI=http://localhost:8080/auth/strava/callback

# ─── Hevy ─────────────────────────────────────────────────────────────────────
# Step 1: Subscribe to Hevy Pro at https://www.hevy.com/pricing
# Step 2: Go to https://hevy.com/settings?developer
# Step 3: Generate and copy your API key here
# NOTE: This is YOUR personal key for testing. Users will submit their own.

HEVY_API_KEY=

# ─── Ethereum / Signing ──────────────────────────────────────────────────────
# Private key for EIP-712 goal verification signing.
# This is NOT a wallet with real funds — generate a fresh key for this purpose.
# Generate: cast wallet new (via Foundry)
# IMPORTANT: Fund this address with a tiny amount of ETH on Base Sepolia
#            so it can be identified as the trusted signer in the contract.

BACKEND_SIGNER_PRIVATE_KEY=

# The contract will store this address as the trusted verification signer.
# Derive it from the private key: cast wallet address --private-key <KEY>

BACKEND_SIGNER_ADDRESS=

# ─── Smart Contract Addresses (Base Sepolia) ─────────────────────────────────
# Fill these AFTER deploying the contract (Day 2).

GOAL_VAULT_ADDRESS=
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── RPC ──────────────────────────────────────────────────────────────────────
# Free public RPC for Base Sepolia.
# For production: use Alchemy, Infura, or QuickNode for higher rate limits.

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# =============================================================================
# STRAVA APP SETUP (One-time, ~5 minutes)
# =============================================================================
#
# 1. Create a Strava account (if you don't have one): https://www.strava.com/register
# 2. Go to https://www.strava.com/settings/api
# 3. Fill in the form:
#    - Application Name:       NazarETH (or your chosen product name)
#    - Category:               Health / Fitness
#    - Club:                    (leave blank)
#    - Authorization Callback Domain: localhost
#    - Website:                 http://localhost:3000
#    - Description:             See STRAVA_APP_DESCRIPTION below
# 4. Click Create — you'll immediately get Client ID and Client Secret
# 5. Copy them to STRAVA_CLIENT_ID and STRAVA_CLIENT_SECRET above
#
# ─── STRAVA APP DESCRIPTION (paste into the form) ────────────────────────────
#
# NazarETH is a fitness commitment platform that helps athletes achieve their
# goals through financial accountability. Users connect their Strava account,
# set a running goal (e.g., "run 10 km this week"), and stake USDC as
# commitment. If they achieve their goal, they get their deposit back plus
# yield earned during the goal period. If they fall short, a graduated
# portion is forfeited based on how close they came — rewarding effort,
# not just binary success. We use Strava activity data (distance, pace,
# timestamps) to objectively verify goal progress. No Strava data is shared
# with third parties — it is used solely to verify the user's own goals.
# Our app is in early development as a student project for Base Batches 003.
#
# ─── STRAVA REVIEW FORM (submit at https://share.hsforms.com/1VXSwPUYqSH6IxK0y51FjHwcnkd8)
# ──────────────────────────────────────────────────────────────────────────────
# Submit this immediately after creating the app to request expanded athlete
# capacity beyond Single Player Mode. The review may take days/weeks.
#
# App name:           NazarETH
# App URL:            http://localhost:3000 (will be updated to production URL)
# Description:        (same as above)
# Number of athletes: 100 (estimated for pilot)
# Use case:           We read athlete activity data (distance, pace, start_time)
#                     to verify whether a user achieved a self-set running goal.
#                     Activities are displayed only to the owning athlete.
# Data handling:      We only access activity:read_all scope. Data is stored
#                     temporarily for goal verification and deleted upon user
#                     request. No data is shared with third parties.

# =============================================================================
# HEVY SETUP (One-time, ~2 minutes)
# =============================================================================
#
# 1. Create a Hevy account: https://www.hevy.com
# 2. Subscribe to Hevy Pro: https://www.hevy.com/pricing (~$4.99/mo)
# 3. Go to https://hevy.com/settings?developer
# 4. Copy your API key to HEVY_API_KEY above
# 5. Test it: curl -H "api-key: YOUR_KEY" https://api.hevyapp.com/v1/workouts

# =============================================================================
# BASE SEPOLIA SETUP (One-time, ~5 minutes)
# =============================================================================
#
# 1. Get testnet ETH:
#    - CDP Faucet:     https://portal.cdp.coinbase.com/products/faucet
#    - Alchemy Faucet:  https://basefaucet.com/
#    - thirdweb Faucet: https://thirdweb.com/base-sepolia-testnet
#
# 2. Get testnet USDC:
#    - CDP Faucet also dispenses USDC on Base Sepolia
#    - Address: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
#
# 3. Generate backend signer key:
#    cast wallet new
#    # Copy the private key to BACKEND_SIGNER_PRIVATE_KEY
#    # Copy the address to BACKEND_SIGNER_ADDRESS
#    # Fund this address with a tiny amount of testnet ETH for gas (if needed)

# =============================================================================
# SMART CONTRACT DEPLOYMENT (Day 2)
# =============================================================================
#
# source .env
# forge script script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC_URL --private-key $DEPLOY_PRIVATE_KEY --broadcast
# # Copy the deployed address to GOAL_VAULT_ADDRESS above
#
# Note: DEPLOY_PRIVATE_KEY is separate from BACKEND_SIGNER_PRIVATE_KEY.
#       The deploy key owns the contract. The signer key is the trusted verifier.

# =============================================================================
# FRONTEND (Vite + React) — these go in frontend/.env
# =============================================================================
# Create a separate frontend/.env file with these values:

# VITE_WALLETCONNECT_PROJECT_ID=
#   → Get from https://cloud.walletconnect.com (free, ~2 min signup)
#   → Create a project, copy the Project ID
#
# VITE_CONTRACT_ADDRESS=
#   → Paste GOAL_VAULT_ADDRESS after deploying
#
# VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
#
# VITE_BACKEND_URL=http://localhost:8080
#
# VITE_CHAIN_ID=84532
